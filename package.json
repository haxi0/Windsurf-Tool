{
  "name": "windsurf-switch",
  "displayName": "Windsurf Switch",
  "description": "Windsurf Multi-Account Seamless Switch — Card-based sidebar, silent account switching without browser popups, cross-window sync, one-click patching; shares account library with desktop version windsurf-manager-desktop. Windows / macOS / Linux compatible.",
  "version": "1.3.0",
  "publisher": "lango",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:windsurfSwitch.sidebar"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "windsurfSwitch",
          "title": "Windsurf Switch",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "windsurfSwitch": [
        {
          "type": "webview",
          "id": "windsurfSwitch.sidebar",
          "name": "",
          "icon": "resources/icon.svg",
          "contextualTitle": "Windsurf Switch"
        }
      ]
    },
    "commands": [
      {
        "command": "windsurfSwitch.switchAccount",
        "title": "Switch Account (QuickPick)",
        "category": "Windsurf Switch",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "windsurfSwitch.switchAccountById",
        "title": "Switch to Specific Account",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.switchByIdToken",
        "title": "Switch with IdToken (Debug)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.addAccount",
        "title": "Add Account",
        "category": "Windsurf Switch",
        "icon": "$(add)"
      },
      {
        "command": "windsurfSwitch.addAccountGitHub",
        "title": "Add Account (Continue with GitHub)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.batchImport",
        "title": "Batch Import",
        "category": "Windsurf Switch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "windsurfSwitch.deleteAccountById",
        "title": "Delete Account (by id)",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.editRemarkById",
        "title": "Edit Remark (by id)",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.showCredentials",
        "title": "View Account Credentials (by id)",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.refreshAccount",
        "title": "Refresh Plan / Quota (by id)",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.fixCredentialsById",
        "title": "Fix Credentials (by id)",
        "category": "Windsurf Switch",
        "enablement": "false"
      },
      {
        "command": "windsurfSwitch.refreshAll",
        "title": "Batch Refresh",
        "category": "Windsurf Switch",
        "icon": "$(sync)"
      },
      {
        "command": "windsurfSwitch.reloadSidebar",
        "title": "Reload Account List",
        "category": "Windsurf Switch",
        "icon": "$(refresh)"
      },
      {
        "command": "windsurfSwitch.openAccountsFile",
        "title": "Open accounts.json Directory",
        "category": "Windsurf Switch",
        "icon": "$(folder)"
      },
      {
        "command": "windsurfSwitch.listAccounts",
        "title": "Account List (Output)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.exportAccounts",
        "title": "Export All Accounts to Clipboard",
        "category": "Windsurf Switch",
        "icon": "$(clippy)"
      },
      {
        "command": "windsurfSwitch.clearExpiredAccounts",
        "title": "Clear Accounts (Expired / Free)",
        "category": "Windsurf Switch",
        "icon": "$(trash)"
      },
      {
        "command": "windsurfSwitch.checkUpdate",
        "title": "Check for Updates",
        "category": "Windsurf Switch",
        "icon": "$(cloud-download)"
      },
      {
        "command": "windsurfSwitch.showOutput",
        "title": "Show Logs",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.smartSwitch",
        "title": "Smart Switch",
        "category": "Windsurf Switch",
        "icon": "$(rocket)"
      },
      {
        "command": "windsurfSwitch.resetSmartCooldown",
        "title": "Reset Smart Switch Cooldown",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.diagnoseSession",
        "title": "Diagnose Login Session (Debug)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.editLogPatterns",
        "title": "Edit Log Monitor Keywords",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.patchWindsurf",
        "title": "Patch Windsurf (Enable No-Browser Switching)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.unpatchWindsurf",
        "title": "Restore Windsurf (Uninstall Patch)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch.checkPatchStatus",
        "title": "Check Windsurf Patch Status",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._refreshCurrentSynced",
        "title": "Internal: Refresh Current Synced Account (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._setPollingInterval",
        "title": "Internal: Set Polling Interval (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._smartSwitchFromSidebar",
        "title": "Internal: Trigger Smart Switch from Sidebar (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._submitAddFromModal",
        "title": "Internal: Submit Add Account Form (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._submitBatchFromModal",
        "title": "Internal: Submit Batch Import Form (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._toggleAuto",
        "title": "Internal: Toggle Auto Switch (for webview)",
        "category": "Windsurf Switch"
      },
      {
        "command": "windsurfSwitch._setLowQuotaThreshold",
        "title": "Internal: Set Auto Switch Threshold (for webview)",
        "category": "Windsurf Switch"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "windsurfSwitch.switchAccountById",
          "when": "false"
        },
        {
          "command": "windsurfSwitch.deleteAccountById",
          "when": "false"
        },
        {
          "command": "windsurfSwitch.editRemarkById",
          "when": "false"
        },
        {
          "command": "windsurfSwitch.showCredentials",
          "when": "false"
        },
        {
          "command": "windsurfSwitch.refreshAccount",
          "when": "false"
        },
        {
          "command": "windsurfSwitch.fixCredentialsById",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._submitAddFromModal",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._submitBatchFromModal",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._smartSwitchFromSidebar",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._toggleAuto",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._setPollingInterval",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._setLowQuotaThreshold",
          "when": "false"
        },
        {
          "command": "windsurfSwitch._refreshCurrentSynced",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "windsurfSwitch.showOutput",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@1"
        },
        {
          "command": "windsurfSwitch.openAccountsFile",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@2"
        },
        {
          "command": "windsurfSwitch.reloadSidebar",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@3"
        },
        {
          "command": "windsurfSwitch.exportAccounts",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@4"
        },
        {
          "command": "windsurfSwitch.clearExpiredAccounts",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@5"
        },
        {
          "command": "windsurfSwitch.checkUpdate",
          "when": "view == windsurfSwitch.sidebar",
          "group": "overflow@6"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --no-dependencies",
    "release": "npm version patch -m \"chore(release): v%s\" && git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haxi0/Windsurf-Tool.git"
  },
  "homepage": "https://github.com/haxi0/Windsurf-Tool#readme",
  "bugs": {
    "url": "https://github.com/haxi0/Windsurf-Tool/issues"
  },
  "author": "haxi0",
  "license": "MIT"
}
